  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "NODE_OPTIONS=--openssl-legacy-provider npm run build",
  "outputDirectory": "build",
  "framework": null,
  "env": {
    "NODE_OPTIONS": "--openssl-legacy-provider",
    "NODE_PATH": "./src",
    "SKIP_PREFLIGHT_CHECK": "true",
