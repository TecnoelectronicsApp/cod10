NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_GRAPHQL_URL=ws://localhost:4000/graphql
# API demo Enatega (inactiva — usar cod10-api local):
# NEXT_PUBLIC_GRAPHQL_URL=https://enatega-singlevendor.up.railway.app/graphql
NEXT_PUBLIC_BCV_API_URL=http://localhost:8000
NEXT_PUBLIC_STORE_CONFIG_URL=https://res.cloudinary.com/dimjm4ald/raw/upload/food/cod10/store-config-v3.json
NEXT_PUBLIC_SITE_URL=https://cod10.vercel.app
# Google Sign-In web (OAuth 2.0 Client ID — autorizar cod10.vercel.app)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Google Maps WEB checkout — OBLIGATORIO (marca Google). Sin tarjeta: usar embed (ver MEMORIA §10).
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_ONLY=true  → fuerza iframe Google (sin API key)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_ONLY=

# --- Bot WhatsApp + Gemini (OpenWA) — solo servidor, no NEXT_PUBLIC ---
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenWA gateway (servidor propio, NO Vercel)
OPENWA_BASE_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=

# Protección API catálogo (opcional)
BOT_API_KEY=

# Firma webhook OpenWA (opcional, recomendado)
WEBHOOK_SECRET=

# --- PROMPT DEL BOT (personalidad / instrucciones IA) ---
# Opción 1 (recomendada): edita el archivo:
#   platform/config/gemini-system-prompt.txt
# Opción 2: define todo el prompt aquí (sobreescribe el archivo):
# GEMINI_SYSTEM_PROMPT=Eres el asistente de Codigo 10...
# Ver prompt activo: GET /api/bot/prompt

