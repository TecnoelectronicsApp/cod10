{
  "name": "food-delivery-singlevendor",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo scripts — ver MEMORIA.md",
  "scripts": {
    "dev:platform": "cd platform && npm run dev",
    "dev:admin": "cd \"Admin Dashboard\" && npm run start:dev",
    "build:platform": "cd platform && npm run build",
    "build:admin": "cd \"Admin Dashboard\" && npm run build",
    "install:all": "cd platform && npm install && cd \"../Admin Dashboard\" && npm install --legacy-peer-deps",
    "fix:food-images": "node scripts/fix-null-food-images.mjs",
    "dev:bcv-api": "cd services/bcv-usd-api && pip install -r requirements.txt && python api_server.py",
    "dev:api": "cd services/cod10-api && npm run dev",
    "seed:api": "cd services/cod10-api && npm run seed",
    "install:api": "cd services/cod10-api && npm install",
    "migrate:enatega": "node scripts/migrate-from-enatega-demo.mjs",
    "setup:atlas": "node scripts/setup-atlas.mjs",
    "memoria": "type MEMORIA.md"
  }
}
